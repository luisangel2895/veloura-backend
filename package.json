{
  "name": "veloura-backend",
  "version": "0.1.0",
  "description": "Veloura — Luxury lingerie e-commerce backend powered by Medusa v2",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "engineStrict": true,
  "scripts": {
    "dev": "npx --yes kill-port 9000 >/dev/null 2>&1 || true; medusa develop",
    "start": "medusa start",
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:prod": "medusa exec ./src/scripts/seed.js",
    "db:setup": "medusa db:setup",
    "db:migrate": "medusa db:migrate",
    "db:rollback": "medusa db:rollback",
    "db:generate": "medusa db:generate",
    "db:sync-links": "medusa db:sync-links",
    "user:create": "medusa user",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "backup": "./scripts/backup-db.sh docker",
    "restore": "./scripts/restore-db.sh"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.5",
    "@medusajs/cli": "2.13.5",
    "@medusajs/file-s3": "2.13.5",
    "@medusajs/framework": "2.13.5",
    "@medusajs/medusa": "2.13.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@medusajs/test-utils": "2.13.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
