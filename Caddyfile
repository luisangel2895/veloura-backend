# ── HTTP-only on server IP (no domain yet, no HTTPS) ──────────────
# Path-based routing — when a real domain is added, switch to the
# subdomain blocks (api.veloura.com / admin.veloura.com) and re-enable
# HSTS in the headers below.
:80 {
	encode gzip

	# MinIO media files (S3-compatible). handle_path strips /media before
	# forwarding, so /media/medusa-media/foo.jpg → minio:9000/medusa-media/foo.jpg
	handle_path /media/* {
		reverse_proxy minio:9000 {
			header_up Host {upstream_hostport}
		}
	}

	# Everything else → Medusa (API at /, admin at /veloura)
	handle {
		reverse_proxy medusa:9000
	}

	header {
		# Security headers (HSTS omitted because we serve plain HTTP)
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "microphone=(), camera=(), geolocation=(), payment=()"
		X-Permitted-Cross-Domain-Policies none
		-Server
	}

	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
