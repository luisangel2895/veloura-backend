# ── Production environment variables ──────────────────────────────
# Copy to .env.prod and fill in real values
# IMPORTANT: All secrets MUST be set — the app will refuse to start without them.

# PostgreSQL
POSTGRES_PASSWORD=

# Auth secrets — REQUIRED in production (app throws on startup if missing)
# Generate each with: openssl rand -hex 32
JWT_SECRET=
COOKIE_SECRET=

# CORS — include the Vercel frontend
STORE_CORS=https://veloura.com,https://veloura-psi.vercel.app
ADMIN_CORS=https://admin.veloura.com
AUTH_CORS=https://veloura.com,https://admin.veloura.com,https://veloura-psi.vercel.app

# Stripe (test mode while still on IP/HTTP — switch to live keys when domain is ready)
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Backend URL — server IP, no domain yet, plain HTTP
MEDUSA_BACKEND_URL=http://161.132.40.176

# MinIO root credentials (also used as S3 access keys via docker-compose)
MINIO_ROOT_USER=veloura_minio
MINIO_ROOT_PASSWORD=

# S3 (MinIO) — internal endpoint Medusa uses to upload
S3_ENDPOINT=http://minio:9000
S3_BUCKET=medusa-media
S3_REGION=us-east-1
# Public URL prefix served by Caddy at /media/* (Caddy strips /media before forwarding)
S3_FILE_URL=http://161.132.40.176/media/medusa-media
