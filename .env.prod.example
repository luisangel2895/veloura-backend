# ── Production environment variables ──────────────────────────────
# Copy to .env.prod and fill in real values.
#
# IMPORTANT: All secrets MUST be set — `medusa-config.ts` throws on
# startup in production if any of JWT_SECRET, COOKIE_SECRET, or
# (with STRIPE_API_KEY set) STRIPE_WEBHOOK_SECRET are missing.

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# Set to "true" to log every SQL statement to medusa stdout (debugging
# only — significantly increases log volume).
DATABASE_LOGGING=false

# ── Auth secrets ──────────────────────────────────────────────────
# Generate each with: openssl rand -hex 32
JWT_SECRET=
COOKIE_SECRET=

# JWT lifetime. 1h is the security default. Lengthen with caution.
JWT_EXPIRES_IN=1h

# Set to "true" once HTTPS is in front of Medusa (real domain). Until
# then, leave false — secure cookies require HTTPS to be sent.
COOKIE_SECURE=false

# ── CORS ──────────────────────────────────────────────────────────
# Include the production storefront origin (Vercel deploy or own domain)
STORE_CORS=https://veloura.com,https://veloura-psi.vercel.app
ADMIN_CORS=https://admin.veloura.com
AUTH_CORS=https://veloura.com,https://admin.veloura.com,https://veloura-psi.vercel.app

# ── Stripe ────────────────────────────────────────────────────────
# Test keys for now — switch to live keys when going to production
# traffic.
STRIPE_API_KEY=sk_test_your_key_here
# REQUIRED in production when STRIPE_API_KEY is set. Without it, Medusa
# silently skips webhook signature validation and an attacker can forge
# payment_intent.succeeded events to mark orders as paid.
STRIPE_WEBHOOK_SECRET=

# ── Backend URL ───────────────────────────────────────────────────
# Server IP for now (no domain yet). Used at BUILD TIME to bake the
# admin UI bundle — when this changes, the medusa image must be rebuilt.
MEDUSA_BACKEND_URL=http://161.132.40.176

# ── MinIO root credentials ────────────────────────────────────────
# Also used as S3 access keys via docker-compose env derivation.
MINIO_ROOT_USER=veloura_minio
MINIO_ROOT_PASSWORD=

# Disable the MinIO web browser console at runtime (we don't expose
# port 9001 anyway, but defense in depth).
MINIO_BROWSER=off

# ── S3 (MinIO) — internal endpoint Medusa uses to upload ─────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=medusa-media
S3_REGION=us-east-1
# Public URL prefix served by Caddy at /media/* (Caddy strips /media
# before forwarding to minio:9000).
S3_FILE_URL=http://161.132.40.176/media/medusa-media
