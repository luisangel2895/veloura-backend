# ── Production environment variables ──────────────────────────────
# Copy to .env.prod and fill in real values
# IMPORTANT: All secrets MUST be set — the app will refuse to start without them.

# PostgreSQL
POSTGRES_PASSWORD=generate-a-strong-password-here

# Auth secrets — REQUIRED in production (app throws on startup if missing)
# Generate each with: openssl rand -hex 32
# Example: openssl rand -hex 32 → 4f3a9c...  (64 hex characters)
JWT_SECRET=
COOKIE_SECRET=

# CORS (your actual domains)
STORE_CORS=https://veloura.com
ADMIN_CORS=https://admin.veloura.com
AUTH_CORS=https://veloura.com,https://admin.veloura.com

# Stripe (use live keys in production)
STRIPE_API_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Backend URL
MEDUSA_BACKEND_URL=https://api.veloura.com

# MinIO
MINIO_ROOT_USER=veloura
MINIO_ROOT_PASSWORD=generate-a-strong-password-here

# Caddy domains
API_DOMAIN=api.veloura.com
ADMIN_DOMAIN=admin.veloura.com
